<Window x:Class="SimpleZipDrive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Simple Zip Drive" Height="600" Width="800"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource ModernWindowStyle}"
        Closing="MainWindow_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="File" ToolTip="File operations">
                <MenuItem Header="Mount Archive..." Click="Mount_ClickAsync" InputGestureText="Ctrl+M" ToolTip="Select a ZIP, 7Z, or RAR archive to mount as a virtual drive" />
                <Separator />
                <MenuItem Header="Exit" Click="Exit_Click" InputGestureText="Alt+F4" ToolTip="Close the application" />
            </MenuItem>
            <MenuItem Header="Settings" ToolTip="Application tools and settings">
                <MenuItem Header="RAM Limit..." Click="SettingsRamLimit_Click" InputGestureText="Ctrl+R" ToolTip="Configure maximum RAM usage per file" />
            </MenuItem>
            <MenuItem Header="Help" ToolTip="Help and information">
                <MenuItem Header="About" Click="About_Click" InputGestureText="F1" ToolTip="View application information and credits" />
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Toolbar -->
            <Border Grid.Row="0" 
                    Background="{StaticResource BgSecondaryBrush}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="3,3,0,0"
                    Padding="10,8"
                    Margin="0,0,0,-1">
                <StackPanel Orientation="Horizontal">
                    <!-- Mount Button -->
                    <Button x:Name="MountButton" 
                            Content="Mount" 
                            Click="Mount_ClickAsync" 
                            Width="90" 
                            Margin="0,0,8,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            ToolTip="Select a ZIP, 7Z, or RAR file to mount" />
                    
                    <!-- Unmount Button -->
                    <Button x:Name="UnmountButton" 
                            Content="Unmount" 
                            Click="Unmount_ClickAsync" 
                            Width="90" 
                            Margin="0,0,8,0"
                            IsEnabled="False"
                            ToolTip="Unmount the currently mounted drive" />
                    
                    <Separator Style="{StaticResource {x:Static StatusBar.SeparatorStyleKey}}" Margin="0,0,16,0" />
                    
                    <!-- Log Buttons -->
                    <Button Content="Copy All" Click="CopyLog_Click" Width="90" Margin="0,0,8,0" ToolTip="Copy all log entries to clipboard" />
                    <Button Content="Clear Log" Click="ClearLog_Click" Width="90" ToolTip="Clear all log entries" />
                </StackPanel>
            </Border>

            <!-- Log Section -->
            <Border Grid.Row="1"
                    Background="{StaticResource BgPrimaryBrush}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="0,0,3,3">
                <TextBox x:Name="LogTextBox"
                         Style="{StaticResource LogTextBoxStyle}"
                         ContextMenu="{StaticResource LogContextMenu}"
                         ToolTip="Application log output. Right-click for options." />
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" ToolTip="Current application status" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="MountStatusText" Text="" ToolTip="Current mount status and drive letter" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
