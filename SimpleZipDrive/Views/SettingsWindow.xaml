<Window x:Class="SimpleZipDrive.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - RAM Limit" Height="260" Width="420"
        WindowStartupLocation="CenterOwner"
         Style="{StaticResource ModernWindowStyle}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="RAM Limit Per File" 
                   FontWeight="SemiBold" 
                   FontSize="16" 
                   Margin="0,0,0,15"
                   ToolTip="Configure memory usage limits for mounted archives" />

        <!-- Settings Group -->
        <GroupBox Grid.Row="1" 
                  Header="Memory Settings" 
                  Padding="15" 
                  Margin="0,0,0,15"
                  ToolTip="Memory configuration settings">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" 
                       Content="Max RAM per file:" 
                       VerticalAlignment="Center" 
                       Margin="0,0,10,0"
                       ToolTip="Maximum amount of RAM to allocate for each mounted file" />
                
                <TextBox x:Name="RamLimitTextBox" 
                         Grid.Column="1" 
                         Width="90" 
                         TextAlignment="Right"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         ToolTip="Enter the maximum RAM limit in megabytes (numeric value only)" />
                
                <Label Grid.Column="2" 
                       Content="MB" 
                       VerticalAlignment="Center" 
                       Margin="8,0,0,0"
                       ToolTip="Megabytes - unit of memory measurement" />
                
                <TextBlock Grid.Column="3" 
                           VerticalAlignment="Center" 
                           Margin="15,0,0,0"
                           Foreground="{StaticResource TextMutedBrush}" 
                           FontStyle="Italic"
                           FontSize="12"
                           Text="(512 MB default)"
                           ToolTip="Default value if not specified" />
            </Grid>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="_Save" 
                    Click="Save_Click" 
                    Width="85" 
                    Margin="0,0,10,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    ToolTip="Save the RAM limit setting" />
            <Button Content="_Cancel" 
                    Click="Cancel_Click" 
                    Width="85"
                    ToolTip="Discard changes and close" />
        </StackPanel>
    </Grid>
</Window>
