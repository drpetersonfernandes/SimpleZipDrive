<Window x:Class="SimpleZipDrive.Core.Views.PasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Required" Height="250" Width="420"
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen"
         Style="{StaticResource ModernWindowStyle}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Style="{StaticResource SubHeaderTextBlockStyle}" Margin="0,0,0,8" ToolTip="Password protection notice">
            <Run Text="The " ToolTip="Password protection notice" />
            <Run x:Name="ArchiveTypeRun" Text="" FontWeight="Bold" Foreground="{StaticResource AccentSecondaryBrush}" ToolTip="Archive file format" />
            <Run Text=" file is password protected." ToolTip="Password protection notice" />
        </TextBlock>

        <!-- File Name -->
        <TextBlock Grid.Row="1" 
                   x:Name="ArchiveNameText" 
                   TextWrapping="Wrap" 
                   Style="{StaticResource MutedTextBlockStyle}"
                   Margin="0,0,0,15"
                   ToolTip="Name of the archive file being opened" />

        <!-- Password Label -->
        <Label Grid.Row="2" 
               Content="Enter password:" 
               Margin="0,0,0,5"
               Style="{StaticResource SemiBoldLabelStyle}"
               ToolTip="Password input field" />
        
        <!-- Password Input -->
        <PasswordBox x:Name="PasswordBox" 
                     Grid.Row="3" 
                     VerticalAlignment="Top"
                     Height="32"
                     Padding="8,0"
                     VerticalContentAlignment="Center"
                     KeyDown="PasswordBox_KeyDown"
                     ToolTip="Type the password for this archive file" />

        <!-- Buttons -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,15,0,0">
            <Button Content="_OK" 
                    Click="Ok_Click" 
                    Width="85" 
                    Margin="0,0,10,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    ToolTip="Confirm password and continue mounting" />
            <Button Content="_Cancel" 
                    Click="Cancel_Click" 
                    Width="85"
                    ToolTip="Cancel mounting this archive" />
        </StackPanel>
    </Grid>
</Window>
