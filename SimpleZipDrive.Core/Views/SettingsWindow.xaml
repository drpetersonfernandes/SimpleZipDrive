<Window x:Class="SimpleZipDrive.Core.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="400" Width="450"
        WindowStartupLocation="CenterOwner"
         Style="{StaticResource ModernWindowStyle}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Settings" 
                   Style="{StaticResource HeaderTextBlockStyle}"
                   Margin="0,0,0,15"
                   ToolTip="Application settings" />

        <!-- RAM Limit Group -->
        <GroupBox Grid.Row="1" 
                  Header="Memory Settings" 
                  Padding="15" 
                  Margin="0,0,0,10"
                  ToolTip="Memory configuration settings">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" 
                       Content="Max RAM per file:" 
                       VerticalAlignment="Center" 
                       Margin="0,0,10,0"
                       ToolTip="Maximum amount of RAM to allocate for each mounted file" />
                
                <TextBox x:Name="RamLimitTextBox" 
                         Grid.Column="1" 
                         Width="90" 
                         TextAlignment="Right"
                         Height="32"
                         VerticalContentAlignment="Center"
                         Padding="8,0"
                         ToolTip="Enter the maximum RAM limit in megabytes (numeric value only)" />
                
                <Label Grid.Column="2" 
                       Content="MB" 
                       VerticalAlignment="Center" 
                       Margin="8,0,0,0"
                       ToolTip="Megabytes - unit of memory measurement" />
                
                <TextBlock Grid.Column="3" 
                           VerticalAlignment="Center" 
                           Margin="15,0,0,0"
                           Style="{StaticResource HintTextBlockStyle}"
                           Text="(512 MB default)"
                           ToolTip="Default value if not specified" />
            </Grid>
        </GroupBox>

        <!-- Mount Type Group -->
        <GroupBox Grid.Row="2" 
                  Header="Mount Settings" 
                  Padding="15" 
                  Margin="0,0,0,15"
                  ToolTip="Mount type configuration settings">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Label Grid.Column="0" 
                       Content="Default mount type:" 
                       VerticalAlignment="Center" 
                       Margin="0,0,10,0"
                       ToolTip="Default method for mounting archives" />
                
                <ComboBox x:Name="MountTypeComboBox" 
                          Grid.Column="1" 
                          Width="180" 
                          Height="32"
                          VerticalContentAlignment="Center"
                          ToolTip="Select the default mount type for archives" />
            </Grid>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="_Save" 
                    Click="Save_Click" 
                    Width="85" 
                    Margin="0,0,10,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    ToolTip="Save settings" />
            <Button Content="_Cancel" 
                    Click="Cancel_Click" 
                    Width="85"
                    ToolTip="Discard changes and close" />
        </StackPanel>
    </Grid>
</Window>
